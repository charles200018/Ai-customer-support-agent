{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/auth/login", "dest": "api/auth/login.js" },
    { "src": "/api/auth/verify", "dest": "api/auth/verify.js" },
    { "src": "/api/auth/logout", "dest": "api/auth/logout.js" },
    { "src": "/api/documents", "dest": "api/documents.js" },
    { "src": "/api/upload", "dest": "api/upload.js" },
    { "src": "/api/chat", "dest": "api/chat.js" },
    { "src": "/api/health/db", "dest": "api/health/db.js" },
    { "src": "/api/health", "dest": "api/health.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}
