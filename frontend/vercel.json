{
  "version": 2,
  "builds": [
    { "src": "src/main.jsx", "use": "@vercel/node" },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
  // NOTE: Set Vercel project root to 'frontend' and build command to 'npm run build' in Vercel dashboard.
}
