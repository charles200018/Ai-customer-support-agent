{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "functions": {
    "frontend/api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/auth/login", "destination": "/frontend/api/auth/login.js" },
    { "source": "/api/auth/verify", "destination": "/frontend/api/auth/verify.js" },
    { "source": "/api/auth/logout", "destination": "/frontend/api/auth/logout.js" },
    { "source": "/api/documents", "destination": "/frontend/api/documents.js" },
    { "source": "/api/upload", "destination": "/frontend/api/upload.js" },
    { "source": "/api/chat", "destination": "/frontend/api/chat.js" },
    { "source": "/api/chat/history", "destination": "/frontend/api/chat.js" },
    { "source": "/api/health/db", "destination": "/frontend/api/health/db.js" },
    { "source": "/api/health", "destination": "/frontend/api/health.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ]
}
