{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/auth/login", "dest": "backend/api/auth/login.js" },
    { "src": "/api/auth/verify", "dest": "backend/api/auth/verify.js" },
    { "src": "/api/auth/logout", "dest": "backend/api/auth/logout.js" },
    { "src": "/api/chat", "dest": "backend/api/chat.js" },
    { "src": "/api/health", "dest": "backend/api/health.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}